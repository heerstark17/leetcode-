class Solution {
public:
    int smallestBalancedIndex(vector<int>& nums) {
        vector<int> psum(nums.size());
       psum[0]=nums[0];
       long long prod=nums[0];
       for(int i=1;i<psum.size();i++){
        psum[i]=nums[i]+psum[i-1];
        prod=prod*nums[i];
       }
     
       
  for(int i=0;i<nums.size();i++){
    prod=prod/nums[i];
    if((psum[i]-nums[i])==prod){
        return i;
    }
  }
   return -1;     
    }
};
